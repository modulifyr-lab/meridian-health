---
interface Props {
  eyebrow: string;
  title: string;
  lede?: string;
}
const { eyebrow, title, lede } = Astro.props;
---

<section class="relative overflow-hidden border-b border-border bg-teal px-6 pb-16 pt-36 md:px-10 md:pb-24 md:pt-44">
  <div class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-gold/10 blur-3xl"></div>
  <div class="absolute -bottom-32 -left-20 h-48 w-48 rounded-full bg-teal-mid/30 blur-3xl"></div>
  <div class="relative z-10 mx-auto max-w-4xl">
    <p class="eyebrow mb-5 text-gold" data-hero-line style="opacity:0">{eyebrow}</p>
    <h1 class="font-display text-balance text-5xl font-semibold leading-[1.02] text-bg md:text-7xl" data-hero-line style="opacity:0">
      {title}
    </h1>
    {lede && (
      <p class="mt-7 max-w-xl text-lg text-bg/80" data-hero-line style="opacity:0">
        {lede}
      </p>
    )}
  </div>
</section>