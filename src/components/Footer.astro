---
const columns = [
  {
    heading: "Services",
    links: [
      { href: "/services", label: "General Medicine" },
      { href: "/services", label: "Cardiology" },
      { href: "/services", label: "Dermatology" },
      { href: "/services", label: "Orthopaedics" },
      { href: "/services", label: "Women's Health" },
      { href: "/services", label: "Mental Health" },
    ],
  },
  {
    heading: "Patient Resources",
    links: [
      { href: "/patient-info", label: "First Visit Guide" },
      { href: "/insurance", label: "Insurance & Billing" },
      { href: "/testimonials", label: "Patient Stories" },
      { href: "/blog", label: "Health Blog" },
      { href: "/facilities", label: "Our Facilities" },
    ],
  },
  {
    heading: "Clinic",
    links: [
      { href: "/about", label: "About Us" },
      { href: "/doctors", label: "Our Doctors" },
      { href: "/careers", label: "Careers" },
      { href: "/contact", label: "Contact" },
    ],
  },
];
---

<footer class="border-t border-border bg-teal-dark text-bg">
  <div class="mx-auto max-w-[1400px] px-6 py-20 md:px-10">
    <div class="grid gap-14 md:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <div>
        <div class="flex items-center gap-3">
          <svg viewBox="0 0 40 40" fill="none" class="h-10 w-10">
            <circle cx="20" cy="20" r="18" fill="#B8923A" fill-opacity="0.15"/>
            <path d="M20 8v24M8 20h24" stroke="#B8923A" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
          <span class="font-display text-2xl font-semibold text-bg">Meridian Health</span>
        </div>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-bg/70">
          Precision Care. Personal Attention. A private clinic founded in 2012 by physicians who believe healthcare should never feel rushed.
        </p>
        <p class="eyebrow mt-8 text-gold">UKAS Accredited · ISO 9001:2015</p>
        <p class="mt-4 text-sm text-bg/70">+1 (555) 240-8800</p>
        <p class="text-sm text-bg/70">appointments@meridianhealthclinic.com</p>
      </div>

      {
        columns.map((col) => (
          <div>
            <p class="eyebrow mb-5 text-gold">{col.heading}</p>
            <ul class="flex flex-col gap-3">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-bg/70 transition-colors hover:text-bg"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div
      class="mt-16 flex flex-col-reverse items-start justify-between gap-6 border-t border-bg/10 pt-8 md:flex-row md:items-center"
    >
      <p class="eyebrow text-bg/50">
        © {new Date().getFullYear()} Meridian Health Clinic. All rights reserved.
      </p>
      <p class="eyebrow text-bg/50">
        Powered by
        <a
          href="https://modulifyr.com"
          target="_blank"
          rel="noopener noreferrer"
          class="text-gold transition-colors hover:text-gold-light"
        >
          Modulifyr
        </a>
      </p>
    </div>
  </div>
</footer>