---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";

const articles = [
  {
    title: "Understanding Your Annual Health Check: What to Ask For and Why",
    author: "Dr. Elena Vasquez",
    dept: "General Medicine",
    excerpt: "Most people know they should get an annual physical, but few know exactly what to ask for. Here's what a comprehensive health assessment should include.",
    date: "December 2024",
  },
  {
    title: "5 Cardiac Warning Signs You Should Never Ignore",
    author: "Dr. Marcus Chen",
    dept: "Cardiology",
    excerpt: "Heart disease remains the leading cause of death globally. Knowing these warning signs could save your life.",
    date: "November 2024",
  },
  {
    title: "PCOS: More Common Than You Think",
    author: "Dr. Priya Nair",
    dept: "Women's Health",
    excerpt: "Polycystic ovary syndrome affects 1 in 10 women, yet many suffer years before diagnosis. Here's what every woman should know.",
    date: "October 2024",
  },
  {
    title: "Skin Cancer Screening: When to See a Dermatologist",
    author: "Dr. Isabella Romano",
    dept: "Dermatology",
    excerpt: "Skin cancer is one of the most treatable forms of cancer — when caught early. Learn the ABCDE warning signs.",
    date: "September 2024",
  },
  {
    title: "Chronic Back Pain: When to Seek Specialist Help",
    author: "Dr. Rajiv Sharma",
    dept: "Orthopaedics",
    excerpt: "Most back pain resolves on its own, but chronic pain needs proper assessment. Here's when to see a specialist.",
    date: "August 2024",
  },
  {
    title: "Mental Health Assessments: Why They Should Be Routine",
    author: "Dr. Sebastian Hartmann",
    dept: "Mental Health",
    excerpt: "Just as we get annual physicals, we should have regular mental health check-ins. Here's why it matters.",
    date: "July 2024",
  },
  {
    title: "Travel Health: Preparing for International Trips",
    author: "Dr. Samuel Osei",
    dept: "General Medicine",
    excerpt: "A pre-travel health assessment can prevent ruined vacations and serious illness. Here's what to consider.",
    date: "June 2024",
  },
];

const featured = {
  title: "Understanding Your Annual Health Check: What to Ask For and Why",
  author: "Dr. Elena Vasquez",
  dept: "General Medicine",
  excerpt: "Most people know they should get an annual physical, but few know exactly what to ask for. Here's what a comprehensive health assessment should include, from basic blood panels to more advanced screenings based on age and risk factors.",
  date: "December 2024",
};
---

<Layout
  title="Health Blog"
  description="Health articles and medical information from the physicians at Meridian Health Clinic."
>
  <PageHeader
    eyebrow="Health Blog"
    title="Medical Insights"
    lede="Health information written by our physicians, not by AI."
  />

  <!-- FEATURED -->
  <section class="px-6 py-20 md:px-10 md:py-28">
    <div class="mx-auto max-w-[1400px]">
      <div class="mb-12" data-reveal>
        <p class="eyebrow text-gold">Featured Article</p>
      </div>
      <div class="rounded-2xl border border-gold bg-teal p-12 md:p-16" data-reveal>
        <p class="eyebrow text-gold/80">{featured.dept}</p>
        <h2 class="mt-4 font-display text-3xl font-semibold text-bg md:text-4xl">
          {featured.title}
        </h2>
        <p class="mt-6 text-lg text-bg/80">{featured.excerpt}</p>
        <div class="mt-8 flex items-center justify-between">
          <div>
            <p class="font-semibold text-bg">{featured.author}</p>
            <p class="eyebrow text-bg/60">{featured.date}</p>
          </div>
          <a href="#" class="eyebrow rounded-full border border-gold px-6 py-3 text-gold transition-all hover:bg-gold hover:text-teal">
            Read More
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ARTICLES -->
  <section class="bg-teal-light px-6 py-20 md:px-10 md:py-28">
    <div class="mx-auto max-w-[1400px]">
      <div class="mb-16 max-w-2xl" data-reveal>
        <p class="eyebrow mb-4 text-gold">All Articles</p>
        <h2 class="font-display text-4xl font-semibold text-teal md:text-5xl">Recent Posts</h2>
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {articles.map((a) => (
          <article class="rounded-xl border border-border bg-white p-8 transition-all hover:border-gold hover:shadow-xl" data-reveal>
            <p class="eyebrow text-green">{a.dept}</p>
            <h3 class="mt-3 font-display text-xl font-semibold text-teal">{a.title}</h3>
            <p class="mt-3 text-muted line-clamp-3">{a.excerpt}</p>
            <div class="mt-6 flex items-center justify-between border-t border-border pt-6">
              <div>
                <p class="text-sm font-medium text-teal">{a.author}</p>
                <p class="eyebrow text-muted">{a.date}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="bg-teal px-6 py-20 text-center md:px-10 md:py-28">
    <div class="mx-auto max-w-2xl" data-reveal>
      <h2 class="font-display text-4xl font-semibold text-bg md:text-5xl">Stay Informed</h2>
      <p class="mt-6 text-lg text-bg/80">
        One email per month with new health articles from our physicians.
      </p>
      <form class="mt-10 flex flex-col gap-4 sm:flex-row" onsubmit="event.preventDefault(); alert('Thank you for subscribing!');">
        <input
          type="email"
          required
          placeholder="Your email address"
          class="flex-1 rounded-full border border-bg/20 bg-transparent px-6 py-4 text-bg placeholder:text-bg/50 focus:border-gold focus:outline-none"
        />
        <button
          type="submit"
          class="eyebrow rounded-full bg-gold px-8 py-4 text-teal transition-all hover:bg-gold-light"
        >
          Subscribe
        </button>
      </form>
      <p class="mt-4 text-sm text-bg/50">No spam. Unsubscribe anytime.</p>
    </div>
  </section>

  <script>
    import { initReveal, initHeroIntro } from "../scripts/animations.js";
    initHeroIntro();
    initReveal();
  </script>
</Layout>