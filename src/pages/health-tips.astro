---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";

const tips = [
  {
    category: "Preventive Care",
    items: [
      { title: "Schedule Annual Check-ups", desc: "Even if you feel well, an annual physical catches issues early when they're most treatable." },
      { title: "Know Your Numbers", desc: "Blood pressure, cholesterol, blood sugar — know your baseline and track changes over time." },
      { title: "Vaccinations Don't Stop at Childhood", desc: "Adults need boosters too. Ask your physician about recommended vaccinations." },
    ],
  },
  {
    category: "Heart Health",
    items: [
      { title: "Move Daily", desc: "30 minutes of moderate exercise most days reduces heart disease risk by 30%." },
      { title: "Know the Warning Signs", desc: "Chest pain, shortness of breath, fatigue — these shouldn't be ignored." },
      { title: "Watch Your Diet", desc: "More plants, less processed food, moderate salt. Your heart will thank you." },
    ],
  },
  {
    category: "Mental Wellbeing",
    items: [
      { title: "Sleep Matters", desc: "7–9 hours for most adults. Poor sleep is linked to everything from weight gain to depression." },
      { title: "Stress Management", desc: "Find what works for you — exercise, meditation, hobbies, or talking to someone." },
      { title: "Reach Out if You Need Help", desc: "Mental health is health. There's no shame in seeking support." },
    ],
  },
];
---

<Layout
  title="Health Tips"
  description="Practical health advice from the physicians at Meridian Health Clinic."
>
  <PageHeader
    eyebrow="Wellness"
    title="Health Tips"
    lede="Simple, evidence-based advice to help you live healthier every day."
  />

  <!-- TIPS -->
  <section class="px-6 py-20 md:px-10 md:py-28">
    <div class="mx-auto max-w-[1400px]">
      {tips.map((section, i) => (
        <div class={`mb-20 ${i % 2 === 0 ? '' : 'bg-teal-light rounded-2xl p-10 md:p-16'}`} data-reveal>
          <h2 class="font-display text-3xl font-semibold text-teal mb-10">{section.category}</h2>
          <div class="grid gap-8 md:grid-cols-3">
            {section.items.map((item) => (
              <div class="rounded-xl border border-border bg-white p-8">
                <h3 class="font-display text-lg font-semibold text-teal">{item.title}</h3>
                <p class="mt-3 text-muted">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-teal px-6 py-20 text-center md:px-10 md:py-28">
    <div class="mx-auto max-w-2xl" data-reveal>
      <h2 class="font-display text-4xl font-semibold text-bg md:text-5xl">
        Questions About Your Health?
      </h2>
      <p class="mt-6 text-lg text-bg/80">
        Book a consultation with one of our physicians for personalised advice.
      </p>
      <a href="/contact" class="mt-10 inline-block rounded-full bg-gold px-10 py-4 text-teal transition-all hover:bg-gold-light hover:shadow-lg">
        Book an Appointment
      </a>
    </div>
  </section>

  <script>
    import { initReveal, initHeroIntro } from "../scripts/animations.js";
    initHeroIntro();
    initReveal();
  </script>
</Layout>