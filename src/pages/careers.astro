---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";

const benefits = [
  { title: "Balanced Hours", desc: "No 10-minute appointments here. Real time with real patients." },
  { title: "Continuing Education", desc: "Annual budget for certifications and conference attendance." },
  { title: "Competitive Compensation", desc: "Salary reviewed annually with performance bonuses." },
  { title: "Collaborative Environment", desc: "Multidisciplinary team meetings and case discussions." },
];

const openings = [
  { title: "Consultant Cardiologist", dept: "Cardiology", type: "Full-time", location: "City Centre" },
  { title: "Registered Nurse", dept: "General Medicine", type: "Full-time", location: "City Centre" },
  { title: "Reception & Patient Care Coordinator", dept: "Operations", type: "Part-time", location: "City Centre" },
];
---

<Layout
  title="Careers"
  description="Join Meridian Health Clinic. We're looking for physicians and staff who share our commitment to unhurried, patient-centred care."
>
  <PageHeader
    eyebrow="Careers"
    title="Join Our Team"
    lede="Healthcare professionals who believe in care over volume."
  />

  <!-- INTRO -->
  <section class="px-6 py-20 md:px-10 md:py-28">
    <div class="mx-auto max-w-[1400px]">
      <div class="mx-auto max-w-3xl text-center" data-reveal>
        <h2 class="font-display text-balance text-4xl font-semibold text-teal md:text-5xl">
          We Hire People Who Care About Care
        </h2>
        <p class="mt-6 text-lg text-muted">
          Meridian Health exists because physicians wanted to practise medicine the way it should be. If you share that belief, we want to hear from you.
        </p>
      </div>
    </div>
  </section>

  <!-- BENEFITS -->
  <section class="bg-teal-light px-6 py-20 md:px-10 md:py-28">
    <div class="mx-auto max-w-[1400px]">
      <div class="mb-16 max-w-2xl" data-reveal>
        <p class="eyebrow mb-4 text-gold">Why Meridian</p>
        <h2 class="font-display text-4xl font-semibold text-teal md:text-5xl">Benefits & Perks</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {benefits.map((b) => (
          <div class="rounded-xl border border-border bg-white p-8" data-reveal>
            <h3 class="font-display text-lg font-semibold text-teal">{b.title}</h3>
            <p class="mt-3 text-muted">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- OPENINGS -->
  <section class="px-6 py-20 md:px-10 md:py-28">
    <div class="mx-auto max-w-[1400px]">
      <div class="mb-16 max-w-2xl" data-reveal>
        <p class="eyebrow mb-4 text-gold">Open Positions</p>
        <h2 class="font-display text-4xl font-semibold text-teal md:text-5xl">Current Openings</h2>
      </div>

      <div class="space-y-6">
        {openings.map((job) => (
          <div class="rounded-2xl border border-border bg-white p-8 transition-all hover:border-gold hover:shadow-xl" data-reveal>
            <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
              <div>
                <h3 class="font-display text-xl font-semibold text-teal">{job.title}</h3>
                <p class="mt-2 text-muted">{job.dept} · {job.location}</p>
              </div>
              <div class="flex gap-3">
                <span class="rounded-full bg-teal-light px-4 py-2 text-sm text-teal">{job.type}</span>
                <a href="/contact" class="eyebrow rounded-full bg-gold px-6 py-2.5 text-teal transition-all hover:bg-gold-light">
                  Apply
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SPECULATIVE -->
  <section class="bg-teal px-6 py-20 md:px-10 md:py-28">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <h2 class="font-display text-4xl font-semibold text-bg md:text-5xl">Don't See Your Role?</h2>
      <p class="mt-6 text-lg text-bg/80">
        We're always interested in meeting exceptional healthcare professionals. Send us your CV and we'll keep it on file.
      </p>
      <a href="mailto:careers@meridianhealthclinic.com" class="mt-10 inline-block rounded-full border border-gold px-10 py-4 text-gold transition-all hover:bg-gold hover:text-teal">
        Send CV
      </a>
    </div>
  </section>

  <script>
    import { initReveal, initHeroIntro } from "../scripts/animations.js";
    initHeroIntro();
    initReveal();
  </script>
</Layout>