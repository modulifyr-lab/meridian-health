---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";

const insurers = [
  "Bupa International",
  "Cigna Global",
  "Aetna International",
  "Allianz Care",
  "AXA-PPP",
  "Aviva",
  "Vitality Health",
  "Zurich Insurance",
];

const faqs = [
  {
    q: "Is my insurance accepted?",
    a: "We work directly with most major international insurance providers. Please see our list of accepted insurers above, or contact us to confirm your specific plan."
  },
  {
    q: "What if my insurer is not listed?",
    a: "We can provide all necessary documentation for you to self-claim. Many patients find their insurer reimburses a significant portion of our fees."
  },
  {
    q: "How does direct billing work?",
    a: "For accepted insurers, we handle the paperwork directly. You only pay your copay or any non-covered portion at the time of your visit."
  },
  {
    q: "Can I pay out-of-pocket?",
    a: "Yes. Self-pay patients enjoy our transparent pricing with no hidden fees. Payment can be made by card, bank transfer, or cash."
  },
  {
    q: "Do you offer multilingual invoices?",
    a: "Yes. Invoices can be provided in English, French, German, Spanish, or Arabic to facilitate your insurance claim or reimbursement."
  },
];

const process = [
  { step: "1", title: "Verify Coverage", desc: "Contact us to confirm your insurance is accepted and understand any copay requirements." },
  { step: "2", title: "Book Appointment", desc: "Schedule your consultation and mention your insurance provider." },
  { step: "3", title: "Arrive with Card", desc: "Bring your physical insurance card to your appointment." },
  { step: "4", title: "We Handle the Rest", desc: "We process the claim directly with your insurer." },
];
---

<Layout
  title="Insurance & Billing"
  description="Meridian Health accepts international insurance. Learn about direct billing, self-pay options, and multilingual invoices."
>
  <PageHeader
    eyebrow="Insurance"
    title="Simple, Transparent Billing"
    lede="We work with major international insurers so you can focus on your health, not paperwork."
  />

  <!-- INSURERS -->
  <section class="px-6 py-20 md:px-10 md:py-28">
    <div class="mx-auto max-w-[1400px]">
      <div class="mb-16 max-w-2xl" data-reveal>
        <p class="eyebrow mb-4 text-gold">Direct Billing Partners</p>
        <h2 class="font-display text-balance text-4xl font-semibold text-teal md:text-5xl">
          Accepted Insurance Providers
        </h2>
        <p class="mt-6 text-lg text-muted">
          We have direct billing agreements with these major international health insurers.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4" data-reveal>
        {insurers.map((ins) => (
          <div class="rounded-xl border border-border bg-white p-6 text-center transition-all hover:border-gold hover:shadow-lg">
            <p class="font-display text-lg font-semibold text-teal">{ins}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="bg-teal-light px-6 py-20 md:px-10 md:py-28">
    <div class="mx-auto max-w-[1400px]">
      <div class="mb-16 max-w-2xl" data-reveal>
        <p class="eyebrow mb-4 text-gold">How It Works</p>
        <h2 class="font-display text-4xl font-semibold text-teal md:text-5xl">Insurance Process</h2>
      </div>

      <div class="grid gap-8 md:grid-cols-4">
        {process.map((p) => (
          <div class="relative" data-reveal>
            <div class="absolute -top-3 -left-2 flex h-10 w-10 items-center justify-center rounded-full bg-gold text-teal font-display font-semibold">
              {p.step}
            </div>
            <div class="pt-12">
              <h3 class="font-display font-semibold text-teal">{p.title}</h3>
              <p class="mt-2 text-muted">{p.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SELF PAY -->
  <section class="px-6 py-20 md:px-10 md:py-28">
    <div class="mx-auto max-w-[1400px]">
      <div class="grid gap-16 md:grid-cols-2 md:items-center">
        <div data-reveal>
          <p class="eyebrow mb-4 text-gold">Self-Pay</p>
          <h2 class="font-display text-balance text-4xl font-semibold text-teal md:text-5xl">
            No Insurance? No Problem.
          </h2>
          <p class="mt-6 text-lg text-muted">
            Many patients choose to pay out-of-pocket. Our transparent pricing means no surprises — you'll know the cost before any treatment.
          </p>
          <div class="mt-8 space-y-4">
            <div class="flex items-center gap-4">
              <span class="text-gold text-xl">✓</span>
              <span class="text-teal">Clear pricing before treatment</span>
            </div>
            <div class="flex items-center gap-4">
              <span class="text-gold text-xl">✓</span>
              <span class="text-teal">No hidden fees</span>
            </div>
            <div class="flex items-center gap-4">
              <span class="text-gold text-xl">✓</span>
              <span class="text-teal">Card, bank transfer, or cash</span>
            </div>
            <div class="flex items-center gap-4">
              <span class="text-gold text-xl">✓</span>
              <span class="text-teal">Multilingual invoices</span>
            </div>
          </div>
        </div>
        <div class="rounded-2xl border border-gold bg-teal p-10" data-reveal>
          <h3 class="font-display text-2xl font-semibold text-bg">Pre-Travel Health Checks</h3>
          <p class="mt-4 text-bg/80">
            Comprehensive health assessments before international travel. From $180+.
          </p>
          <p class="mt-6 text-bg/60 text-sm">
            Includes full physical, blood work, travel vaccinations guidance, and personalised health advice for your destination.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQS -->
  <section class="bg-teal-light px-6 py-20 md:px-10 md:py-28">
    <div class="mx-auto max-w-[1400px]">
      <div class="mb-16 max-w-2xl" data-reveal>
        <p class="eyebrow mb-4 text-gold">Questions</p>
        <h2 class="font-display text-4xl font-semibold text-teal md:text-5xl">Frequently Asked</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {faqs.map((f) => (
          <div class="rounded-xl border border-border bg-white p-8" data-reveal>
            <h3 class="font-display text-lg font-semibold text-teal">{f.q}</h3>
            <p class="mt-3 text-muted">{f.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script>
    import { initReveal, initHeroIntro } from "../scripts/animations.js";
    initHeroIntro();
    initReveal();
  </script>
</Layout>