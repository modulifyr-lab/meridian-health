---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Page Not Found"
  description="The page you're looking for couldn't be found."
>
  <section class="min-h-[70vh] flex items-center justify-center bg-teal px-6 pt-20">
    <div class="text-center">
      <p class="font-display text-8xl font-semibold text-gold">404</p>
      <h1 class="mt-4 font-display text-4xl font-semibold text-bg">Page Not Found</h1>
      <p class="mt-4 text-bg/70">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a href="/" class="mt-10 inline-block rounded-full bg-gold px-8 py-4 text-teal transition-all hover:bg-gold-light hover:shadow-lg">
        Return Home
      </a>
    </div>
  </section>
</Layout>